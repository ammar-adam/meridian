# Required — AI pipeline
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Startup sourcing — StartupHub New AI startups feed (1 credit/search)
# https://www.startuphub.ai — free tier available
STARTUPHUB_API_KEY=

# Optional enterprise — add later when a fund licenses PitchBook
PITCHBOOK_API_KEY=

# Model overrides (defaults preserve quality — see lib/api-models.js)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
PERPLEXITY_RESEARCH_MODEL=sonar-deep-research
PERPLEXITY_SEARCH_MODEL=sonar

# ── Cloud productization (Tier 1) ─────────────────────────────────────────

# Neon Postgres — enables durable shares, teams, cross-device sync
# Create free DB: https://neon.tech → copy connection string
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk auth — enables sign-in + workspace sync
# Create app: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# After adding DATABASE_URL, push schema:
#   npm run db:push
#   npm run db:migrate

# Feature flags
MERIDIAN_ENABLE_SERVER_PDF=true
# Share links auto-enable when DATABASE_URL is set. Leave blank unless forcing on without DB.
MERIDIAN_ENABLE_SHARE_LINKS=

# Vercel cron — background batch processing (set on Vercel, random string)
CRON_SECRET=

# Server PDF on Vercel — pack is built into public/chromium-pack.tar at deploy time.
# Optional override; defaults to https://<vercel-host>/chromium-pack.tar
# CHROMIUM_REMOTE_EXEC_PATH=
