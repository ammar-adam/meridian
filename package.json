{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#lib/*": "./lib/*",
    "@/*": "./*"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:watch": "vitest",
    "test:ci": "npm run lint && npm run test:unit && npm run build",
    "postinstall": "node scripts/fetch-chromium-pack.js || true && npx playwright install chromium || true",
    "db:push": "drizzle-kit push",
    "db:migrate": "node scripts/migrate-batch-jobs.mjs",
    "db:studio": "drizzle-kit studio",
    "smoke": "node scripts/acceptance-smoke.mjs",
    "debate": "node scripts/adversarial-debate.mjs",
    "demo:preflight": "./scripts/demo-preflight.sh",
    "demo:ready": "npm run test:unit && node scripts/adversarial-debate.mjs",
    "prod:pump": "./scripts/prod-pump.sh"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.7.5",
    "@neondatabase/serverless": "^1.1.0",
    "@sparticuz/chromium-min": "^149.0.0",
    "drizzle-orm": "^0.45.2",
    "next": "14.2.35",
    "playwright": "^1.49.1",
    "playwright-core": "^1.61.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "vitest": "^4.1.9"
  }
}
